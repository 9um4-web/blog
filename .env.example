# Postgres 연결 문자열
DATABASE_URL=postgres://blog:blog@localhost:5432/blog

# 세션 쿠키 서명 키 (openssl rand -hex 32 등으로 생성)
SESSION_SECRET=

# 관리자 비밀번호의 bcrypt 해시
# 생성: node -e "console.log(require('bcryptjs').hashSync('비밀번호', 10))"
# 주의: Next.js가 .env의 $를 변수 확장하므로 모든 $를 \$로 이스케이프하세요
# 예: $2b$10$abc... → \$2b\$10\$abc...
ADMIN_PASSWORD_HASH=

# 배포 도메인 (og:url, canonical, 사이트맵 등 절대 URL 생성에 사용). 미설정 시 운영 도메인으로 폴백
NEXT_PUBLIC_SITE_URL=https://blog.9um4.com
